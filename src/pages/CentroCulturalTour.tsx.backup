import { useEffect, useRef, useState } from "react";
import { useNavigate } from "react-router-dom";
import { ArrowLeft } from "lucide-react";
import tourCasaVideo from "@/assets/Casa-Costa/TOURCASA1.mp4";

const CentroCulturalTour = () => {
  const videoRef = useRef<HTMLVideoElement>(null);
  const sectionRef = useRef<HTMLDivElement>(null);
  const navigate = useNavigate();
  const [progress, setProgress] = useState(0);
  const [targetProgress, setTargetProgress] = useState(0);
  const currentProgressRef = useRef(0);
  const animationRef = useRef<number | null>(null);
  const prevScrollYRef = useRef(0);
  const prevRawProgressRef = useRef(0);
  const scrollAccumulatorRef = useRef(0);
  const maxScrollRef = useRef(0);
  const lastTargetProgressRef = useRef(0);
  const isProgrammaticScrollRef = useRef(false);
  const [totalFrames, setTotalFrames] = useState(0);
  const totalFramesRef = useRef(0);
  const frameRateRef = useRef(30); // Suposición inicial, podríamos detectar
  const lastTimeRef = useRef<number | null>(null);

  useEffect(() => {
    const video = videoRef.current;
    if (!video) return;

    // Configurar video sin audio
    video.muted = true;
    video.pause();

    // Agregar clases al body y html para permitir scroll
    document.body.classList.add("tour-scroll-enabled");
    document.documentElement.classList.add("tour-scroll-enabled");

    let rafId: number | null = null;
    let ticking = false;

    const updateProgress = () => {
      if (!video) return;

      const windowHeight = window.innerHeight;
      const scrollY = window.scrollY;

      // Calcular el scroll máximo real del documento
      // scrollHeight es la altura total del documento
      // scroll máximo es scrollHeight - windowHeight
      const scrollHeight = document.documentElement.scrollHeight;
      const maxScroll = Math.max(1, scrollHeight - windowHeight);
      maxScrollRef.current = maxScroll;


      // Calcular progreso crudo (0 a 1)
      let rawProgress = maxScroll > 0 ? Math.min(scrollY / maxScroll, 1) : 0;
      rawProgress = Math.max(0, rawProgress);

      // Limitar cambio a máximo 1 frame por actualización (o 1% si no hay frames)
      let limitedProgress = rawProgress;
      const deltaFromLast = rawProgress - lastTargetProgressRef.current;
      const maxDelta = totalFramesRef.current > 0 ? 1 / totalFramesRef.current : 0.01;
      if (Math.abs(deltaFromLast) > maxDelta) {
        limitedProgress = lastTargetProgressRef.current + Math.sign(deltaFromLast) * maxDelta;
      }
      const easedProgress = limitedProgress;
      lastTargetProgressRef.current = limitedProgress;

      // Calcular delta para debug (solo después del primer frame)
      let deltaScrollY = 0;
      let deltaProgress = 0;
      if (prevScrollYRef.current !== 0 || prevRawProgressRef.current !== 0) {
        deltaScrollY = scrollY - prevScrollYRef.current;
        deltaProgress = rawProgress - prevRawProgressRef.current;
      }

      // Para debug: console.log solo en desarrollo
      if (process.env.NODE_ENV === 'development') {
        console.log('Scroll debug:', {
          scrollY,
          deltaScrollY,
          deltaProgressPercent: (deltaProgress * 100).toFixed(2) + '%',
          windowHeight,
          scrollHeight,
          maxScroll,
          progressRaw: rawProgress,
          easedProgress,
          lastTargetProgress: lastTargetProgressRef.current,
          limited: Math.abs(deltaFromLast) > 0.01 ? 'YES' : 'NO'
        });
      }

      // Actualizar referencias para siguiente cálculo
      prevScrollYRef.current = scrollY;
      prevRawProgressRef.current = rawProgress;

      setTargetProgress(easedProgress);

      ticking = false;
    };

    const handleScroll = () => {
      if (isProgrammaticScrollRef.current) {
        isProgrammaticScrollRef.current = false;
        return;
      }
      if (!ticking) {
        ticking = true;
        rafId = requestAnimationFrame(updateProgress);
      }
    };

    const handleResize = () => {
      // Recalcular en resize
      if (!ticking) {
        ticking = true;
        rafId = requestAnimationFrame(updateProgress);
      }
    };

    const handleWheel = (e: WheelEvent) => {
      e.preventDefault();

      // Calcular maxScroll si aún no está inicializado
      if (maxScrollRef.current <= 0) {
        const scrollHeight = document.documentElement.scrollHeight;
        const windowHeight = window.innerHeight;
        maxScrollRef.current = Math.max(1, scrollHeight - windowHeight);
      }

      const delta = e.deltaY;
      scrollAccumulatorRef.current += delta;

      // Calcular threshold basado en frames (un frame por step) o 1% si no hay frames
      const frameThreshold = totalFramesRef.current > 0 ? maxScrollRef.current / totalFramesRef.current : maxScrollRef.current * 0.01;
      const threshold = frameThreshold;

      if (Math.abs(scrollAccumulatorRef.current) >= threshold) {
        const steps = Math.floor(Math.abs(scrollAccumulatorRef.current) / threshold);
        const direction = Math.sign(scrollAccumulatorRef.current);

        // Debug
        if (process.env.NODE_ENV === 'development') {
          console.log('Wheel event:', {
            delta,
            accumulator: scrollAccumulatorRef.current,
            threshold,
            steps,
            direction,
            currentProgress: currentProgressRef.current
          });
        }

        // Calcular nuevo progreso basado en el último target (no el interpolado)
        const frameIncrement = totalFramesRef.current > 0 ? 1 / totalFramesRef.current : 0.01;
        let newProgress = lastTargetProgressRef.current + (direction * steps * frameIncrement);
        newProgress = Math.max(0, Math.min(1, newProgress));

        // Actualizar targetProgress y lastTargetProgressRef
        setTargetProgress(newProgress);
        lastTargetProgressRef.current = newProgress;

        // Actualizar scroll position para que coincida con el nuevo progreso
        isProgrammaticScrollRef.current = true;
        const newScrollY = newProgress * maxScrollRef.current;
        window.scrollTo(0, newScrollY);

        // Mantener el residuo en el acumulador
        scrollAccumulatorRef.current = scrollAccumulatorRef.current - (direction * steps * threshold);
      }
    };

    // Esperar a que el video cargue metadatos para conocer su duración
    const handleLoadedMetadata = () => {
      // Calcular total de frames basado en duración y frame rate (asumido 30 fps)
      if (video.duration && !isNaN(video.duration)) {
        const frames = Math.floor(video.duration * frameRateRef.current);
        totalFramesRef.current = frames;
        setTotalFrames(frames);
        console.log('Video metadata:', {
          duration: video.duration,
          totalFrames: frames,
          frameRate: frameRateRef.current
        });
      }
      // Iniciar listeners
      window.addEventListener("scroll", handleScroll, { passive: true });
      window.addEventListener("resize", handleResize);
      window.addEventListener("wheel", handleWheel, { passive: false });
      // Actualizar progreso inicial
      updateProgress();
    };

    if (video.readyState >= 1) {
      // Video ya tiene metadatos
      handleLoadedMetadata();
    } else {
      video.addEventListener("loadedmetadata", handleLoadedMetadata);
    }

    // Forzar un recalculo después de que se apliquen los estilos
    setTimeout(() => {
      updateProgress();
    }, 100);

    // Limpiar todo al desmontar
    return () => {
      window.removeEventListener("scroll", handleScroll);
      window.removeEventListener("resize", handleResize);
      window.removeEventListener("wheel", handleWheel);
      video.removeEventListener("loadedmetadata", handleLoadedMetadata);
      if (rafId) {
        cancelAnimationFrame(rafId);
      }
      // Remover clases
      document.body.classList.remove("tour-scroll-enabled");
      document.documentElement.classList.remove("tour-scroll-enabled");
    };
  }, []);

  // Efecto para interpolación suave del tiempo de video
  useEffect(() => {
    const video = videoRef.current;
    if (!video) return;

    const animate = (currentTime: number) => {
      // Calcular delta time para interpolación independiente del framerate
      if (lastTimeRef.current === null) {
        lastTimeRef.current = currentTime;
      }
      const deltaTime = Math.min(currentTime - lastTimeRef.current, 100); // Limitamos a 100ms máximo
      lastTimeRef.current = currentTime;

      // Factor de interpolación basado en tiempo (apuntamos a ~100ms para alcanzar el target)
      const SMOOTHING_TIME = 100; // ms
      const smoothingFactor = Math.min(deltaTime / SMOOTHING_TIME, 1);

      // Interpolación exponencial suave hacia targetProgress
      const diff = targetProgress - currentProgressRef.current;
      if (Math.abs(diff) < 0.0001) {
        currentProgressRef.current = targetProgress;
      } else {
        currentProgressRef.current += diff * smoothingFactor;
      }

      // Actualizar tiempo del video usando frames
      if (video.duration && !isNaN(video.duration) && totalFrames > 0) {
        const frameIndex = Math.round(currentProgressRef.current * totalFrames);
        // Asegurar que frameIndex esté dentro de los límites (0 a totalFrames)
        const clampedFrameIndex = Math.min(Math.max(frameIndex, 0), totalFrames);
        video.currentTime = Math.min(clampedFrameIndex / frameRateRef.current, video.duration);
      } else if (video.duration && !isNaN(video.duration)) {
        // Fallback a la lógica original si totalFrames no está disponible
        video.currentTime = currentProgressRef.current * video.duration;
      }

      // Actualizar progreso UI para barra suave
      setProgress(currentProgressRef.current);

      animationRef.current = requestAnimationFrame(animate);
    };

    animationRef.current = requestAnimationFrame(animate);

    return () => {
      if (animationRef.current) {
        cancelAnimationFrame(animationRef.current);
      }
    };
  }, [targetProgress, totalFrames]);

  const currentFrame = totalFrames > 0 ? Math.round(progress * totalFrames) : 0;
  const frameProgress = totalFrames > 0 ? currentFrame / totalFrames : progress;
  const framePercentage = totalFrames > 0 ? Math.round((currentFrame / totalFrames) * 100) : Math.round(progress * 100);

  const formatProgress = () => {
    if (totalFrames > 0) {
      return `Frame ${currentFrame}`;
    }
    const percentage = Math.round(progress * 100);
    return `${percentage}%`;
  };

  return (
    <div className="min-h-screen bg-navy-deep">
      {/* Botón de volver */}
      <button
        onClick={() => navigate(-1)}
        className="fixed top-8 left-8 z-50 flex items-center gap-2 px-4 py-2.5 rounded-xl glass text-white/90 hover:text-white hover:bg-white/10 transition-all duration-300 backdrop-blur-sm"
      >
        <ArrowLeft className="w-4 h-4" />
        <span className="text-sm font-medium">Volver al sitio</span>
      </button>

      {/* Contenido principal - El scroll es controlado por la altura del body (200vh) */}
      <div ref={sectionRef} className="w-full min-h-screen relative">
        <video
          ref={videoRef}
          src={tourCasaVideo}
          className="fixed inset-0 w-full h-full object-cover"
          playsInline
          preload="auto"
          muted
        />

        {/* Overlay de información */}
        <div className="fixed inset-0 flex flex-col justify-between p-8 md:p-12 pointer-events-none z-10">
          {/* Título en la parte superior */}
          <div className="max-w-3xl">
            <h1 className="font-heading text-5xl md:text-7xl font-bold text-white mb-4">
              Tour Virtual de Casa Costa
            </h1>
            <p className="text-white/80 text-lg md:text-xl max-w-2xl">
              Desplázate para explorar cada rincón de nuestro centro cultural.
            </p>
          </div>

          {/* Indicador de progreso en la parte inferior */}
          <div className="flex flex-col items-start">
            <div className="mb-4">
              <div className="flex items-center gap-3 mb-2">
                <span className="text-white/80 text-sm">
                  {progress < 0.01 ? "Desplázate hacia abajo para comenzar" : progress >= 0.99 ? "Tour completado" : "Desplázate para avanzar"}
                </span>
                <span className="text-white text-sm font-medium px-2 py-1 rounded-md bg-white/20">
                  {formatProgress()}
                </span>
              </div>
              <div className="w-64 h-2 bg-white/30 rounded-full overflow-hidden">
                <div
                  className="h-full bg-gradient-to-r from-yellow to-yellow-soft rounded-full transition-all duration-300"
                  style={{ width: `${frameProgress * 100}%` }}
                />
              </div>
            </div>

            <p className="text-white/60 text-sm">
              El video avanza automáticamente según tu desplazamiento • Sin audio
            </p>
          </div>
        </div>

        {/* Indicador de scroll en el centro cuando está inactivo */}
        {progress < 0.1 && (
          <div className="fixed inset-0 flex items-center justify-center pointer-events-none z-0">
            <div className="flex flex-col items-center animate-pulse">
              <div className="text-white/60 text-lg mb-4">Desplázate hacia abajo para comenzar</div>
              <div className="w-8 h-12 border-2 border-white/40 rounded-full flex justify-center">
                <div className="w-1 h-4 bg-white/60 rounded-full mt-2 animate-bounce" />
              </div>
            </div>
          </div>
        )}

        {/* Degradado sutil en los bordes */}
        <div className="fixed inset-0 bg-gradient-to-b from-navy-deep/40 via-transparent to-navy-deep/40 pointer-events-none" />
        <div className="fixed inset-0 bg-gradient-to-r from-navy-deep/30 via-transparent to-navy-deep/30 pointer-events-none" />
      </div>
    </div>
  );
};

export default CentroCulturalTour;